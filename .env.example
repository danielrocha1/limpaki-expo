# Copie para .env na raiz do projeto (Expo / scripts npm).

# --- Expo (obrigatorio para apontar o app) ---
EXPO_PUBLIC_API_URL=https://limpaki-expo-fvjj.onrender.com

# Web CRA legado (se existir build que le isto):
# REACT_APP_API_URL=https://limpaki-expo-fvjj.onrender.com

# Desativar fluxo de planos apos cadastro (padrao: habilitado)
# EXPO_PUBLIC_SUBSCRIPTION_CHECKOUT_ENABLED=false

# WhatsApp do suporte na Central de Ajuda (somente numeros, ex.: 5511999999999)
# EXPO_PUBLIC_SUPPORT_WHATSAPP=5511999999999

# Checkout MP: o app usa sandbox_init_point antes de init_point quando ambos existem (token de teste).

# --- Proxy local (npm run proxy:web / start:proxy): encaminha :8787 para o backend ---
# Por defeito o script ja usa limpaki-expo; define isto so para Go na maquina:
# LIMPAE_PROXY_TARGET=http://127.0.0.1:8080
# LIMPAE_PROXY_PORT=8787

# Backend Go: variaveis em go/src/config/.env.example (DATABASE_URL, JWT, Resend, Mercado Pago, etc.)
