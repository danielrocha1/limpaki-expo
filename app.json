{
  "expo": {
    "name": "Limpae Expo",
    "slug": "limpae-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "public/*",
      "src/img/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "A Limpae usa sua localizacao para compartilhar a posicao em tempo real no chat do servico."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d8c74"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.dsoftwarehouse.limpaeexpo"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "2550c088-650c-424c-ab1c-c4c6bbba19b0"
      }
    }
  }
}
