# Copie para go/src/config/.env em desenvolvimento local (ConnectDB carrega este arquivo).

# --- Obrigatorias ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE
JWT_SECRET=your-jwt-secret

# --- Servidor ---
PORT=4000
APP_ENV=development

# --- CORS / links do app (verificacao de e-mail, redirects) ---
FRONT_END_URL=http://localhost:3000
# FRONT_END_URL1=https://outro-front.onrender.com
# ALLOWED_ORIGINS=https://app.exemplo.com,https://outro.exemplo.com
# APP_URL=
# PUBLIC_APP_URL=

# --- Usuarios de teste (premium sem assinatura) ---
# Lista separada por virgula; so aplica no cadastro (POST /api/users). Nao pode ser alterada pela API.
# INTERNAL_TEST_USER_EMAILS=qa@limpae.app

# --- E-mail (Resend — verificacao de conta) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@seudominio.com
RESEND_FROM_NAME=Limpae

# --- E-mail legado SMTP (upload/alertas; opcional) ---
# EMAIL_FROM=
# EMAIL_ALERT_TO=
# EMAIL_PASSWORD=

# --- Supabase Storage (fotos de perfil) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=user-photos

# --- Mercado Pago (Checkout Pro) ---
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_URL=https://seu-host.onrender.com/api/mercadopago/webhook
# MERCADO_PAGO_SUCCESS_URL=
# MERCADO_PAGO_FAILURE_URL=
# MERCADO_PAGO_PENDING_URL=
# SUBSCRIPTION_SUCCESS_URL=
# SUBSCRIPTION_FAILURE_URL=
# SUBSCRIPTION_PENDING_URL=
# SUBSCRIPTION_WEBHOOK_URL=

# --- Chat WebSocket (opcional; padrao herda CORS do backend) ---
# CHAT_ALLOWED_ORIGINS=
# CHAT_LOCATION_MIN_INTERVAL=1s
# CHAT_WS_READ_BUFFER=1024
# CHAT_WS_WRITE_BUFFER=1024
